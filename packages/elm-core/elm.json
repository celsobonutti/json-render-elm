{
    "type": "package",
    "name": "json-render/elm",
    "summary": "Elm renderer for the json-render generative UI framework",
    "license": "Apache-2.0",
    "version": "1.0.0",
    "exposed-modules": [
        "JsonRender",
        "JsonRender.Internal.Condition",
        "JsonRender.Internal.Effect",
        "JsonRender.Internal.PropValue",
        "JsonRender.Spec",
        "JsonRender.State",
        "JsonRender.Resolve",
        "JsonRender.Visibility",
        "JsonRender.Render",
        "JsonRender.Actions",
        "JsonRender.Bind",
        "JsonRender.Events",
        "JsonRender.Validation"
    ],
    "elm-version": "0.19.0 <= v < 0.20.0",
    "dependencies": {
        "NoRedInk/elm-json-decode-pipeline": "1.0.0 <= v < 2.0.0",
        "TSFoster/elm-uuid": "4.3.1 <= v < 5.0.0",
        "elm/core": "1.0.0 <= v < 2.0.0",
        "elm/regex": "1.0.0 <= v < 2.0.0",
        "micahhahn/elm-safe-recursion": "2.0.0 <= v < 3.0.0",
        "elm/html": "1.0.0 <= v < 2.0.0",
        "elm/json": "1.1.0 <= v < 2.0.0",
        "elm/random": "1.0.0 <= v < 2.0.0"
    },
    "test-dependencies": {
        "elm-explorations/test": "2.0.0 <= v < 3.0.0"
    }
}
