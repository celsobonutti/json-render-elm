{
  "state": { "items": [{ "id": "1", "title": "Existing Item" }] },
  "root": "stack",
  "elements": {
    "stack": {
      "type": "Stack",
      "props": { "direction": "vertical" },
      "children": ["btn", "list"]
    },
    "btn": {
      "type": "Button",
      "props": { "label": "Add Item" },
      "children": [],
      "on": {
        "press": {
          "action": "pushState",
          "params": {
            "statePath": "/items",
            "value": { "id": "new", "title": "New Item" }
          }
        }
      }
    },
    "list": {
      "type": "Stack",
      "props": { "direction": "vertical" },
      "children": ["item"],
      "repeat": { "statePath": "/items", "key": "id" }
    },
    "item": {
      "type": "Text",
      "props": { "content": { "$item": "title" } },
      "children": []
    }
  }
}
