{
  "state": { "clicked": false },
  "root": "stack",
  "elements": {
    "stack": {
      "type": "Stack",
      "props": { "direction": "vertical" },
      "children": ["btn", "status"]
    },
    "btn": {
      "type": "Button",
      "props": { "label": "Click Me" },
      "children": [],
      "on": {
        "press": {
          "action": "setState",
          "params": { "statePath": "/clicked", "value": true }
        }
      }
    },
    "status": {
      "type": "Text",
      "props": { "content": "Clicked!" },
      "children": [],
      "visible": { "$state": "/clicked" }
    }
  }
}
