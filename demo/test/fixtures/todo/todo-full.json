{
  "root": "main",
  "elements": {
    "main": {
      "type": "Card",
      "props": {
        "title": "My To-Do List"
      },
      "children": [
        "add-stack",
        "todo-list"
      ]
    },
    "add-stack": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 8
      },
      "children": [
        "new-todo-input",
        "add-btn"
      ]
    },
    "new-todo-input": {
      "type": "Input",
      "props": {
        "placeholder": "Add a new task...",
        "label": "New Task",
        "value": {
          "$bindState": "/newTodoText"
        }
      },
      "children": []
    },
    "add-btn": {
      "type": "Button",
      "props": {
        "label": "Add",
        "variant": "primary"
      },
      "on": {
        "press": {
          "action": "pushState",
          "params": {
            "statePath": "/todos",
            "value": {
              "id": "$id",
              "title": {
                "$state": "/newTodoText"
              },
              "completed": false
            },
            "clearStatePath": "/newTodoText"
          }
        }
      },
      "children": []
    },
    "todo-list": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 8
      },
      "repeat": {
        "statePath": "/todos",
        "key": "id"
      },
      "children": [
        "todo-card"
      ]
    },
    "todo-card": {
      "type": "Card",
      "props": {
        "title": {
          "$item": "title"
        }
      },
      "children": [
        "todo-actions"
      ]
    },
    "todo-actions": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 8
      },
      "children": [
        "todo-badge",
        "toggle-btn",
        "delete-btn"
      ]
    },
    "todo-badge": {
      "type": "Badge",
      "props": {
        "label": {
          "$cond": {
            "$item": "completed"
          },
          "$then": "Completed",
          "$else": "To-Do"
        },
        "color": {
          "$cond": {
            "$item": "completed"
          },
          "$then": "green",
          "$else": "yellow"
        }
      },
      "children": []
    },
    "toggle-btn": {
      "type": "Button",
      "props": {
        "label": {
          "$cond": {
            "$item": "completed"
          },
          "$then": "Mark To-Do",
          "$else": "Mark Completed"
        },
        "variant": {
          "$cond": {
            "$item": "completed"
          },
          "$then": "secondary",
          "$else": "primary"
        }
      },
      "on": {
        "press": {
          "action": "setState",
          "params": {
            "statePath": {
              "$item": "completed"
            },
            "value": {
              "$cond": {
                "$item": "completed"
              },
              "$then": false,
              "$else": true
            }
          }
        }
      },
      "children": []
    },
    "delete-btn": {
      "type": "Button",
      "props": {
        "label": "Delete",
        "variant": "danger"
      },
      "on": {
        "press": {
          "action": "removeState",
          "params": {
            "statePath": "/todos",
            "index": {
              "$index": true
            }
          }
        }
      },
      "children": []
    }
  },
  "state": {
    "newTodoText": "",
    "todos": [
      {
        "id": "1",
        "title": "Buy groceries",
        "completed": false
      },
      {
        "id": "2",
        "title": "Read a book",
        "completed": true
      },
      {
        "id": "3",
        "title": "Go for a run",
        "completed": false
      },
      {
        "id": "4",
        "title": "Write project proposal",
        "completed": false
      }
    ]
  }
}
