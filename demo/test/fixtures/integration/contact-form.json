{
  "state": { "form": { "name": "" }, "submitted": false },
  "root": "form",
  "elements": {
    "form": {
      "type": "Card",
      "props": { "title": "Contact Us" },
      "children": ["name-input", "submit-btn", "success-msg"]
    },
    "name-input": {
      "type": "Input",
      "props": {
        "value": { "$bindState": "/form/name" },
        "label": "Name",
        "placeholder": "Your name"
      },
      "children": []
    },
    "submit-btn": {
      "type": "Button",
      "props": { "label": "Send" },
      "children": [],
      "on": {
        "press": {
          "action": "setState",
          "params": { "path": "/submitted", "value": true }
        }
      }
    },
    "success-msg": {
      "type": "Text",
      "props": { "content": { "$template": "Thanks, ${/form/name}!" } },
      "children": [],
      "visible": { "$state": "/submitted" }
    }
  }
}
