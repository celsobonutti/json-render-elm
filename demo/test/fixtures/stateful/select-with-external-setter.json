{
  "root": "stack",
  "elements": {
    "stack": {
      "type": "Stack",
      "props": { "direction": "vertical", "gap": 8 },
      "children": ["display", "select1", "set-grape-btn"]
    },
    "select1": {
      "type": "Select",
      "props": {
        "label": "Fruit",
        "placeholder": "Pick a fruit...",
        "options": ["Apple", "Banana", "Cherry", "Date", "Elderberry", "Fig", "Grape"],
        "value": { "$bindState": "/selected" }
      },
      "on": {
        "change": {
          "action": "setState",
          "params": {
            "statePath": "/changed",
            "value": true
          }
        }
      }
    },
    "display": {
      "type": "Text",
      "props": {
        "content": { "$template": "Selected: ${/selected}" }
      }
    },
    "set-grape-btn": {
      "type": "Button",
      "props": { "label": "Set Grape" },
      "on": {
        "press": {
          "action": "setState",
          "params": {
            "statePath": "/selected",
            "value": "Grape"
          }
        }
      }
    }
  },
  "state": {
    "selected": "",
    "changed": false
  }
}
