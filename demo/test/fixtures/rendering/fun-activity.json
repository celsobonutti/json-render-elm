{
  "root": "main",
  "elements": {
    "main": {
      "type": "Stack",
      "props": {
        "direction": "vertical",
        "gap": 4
      },
      "children": ["header", "quiz-card", "result-card"]
    },
    "header": {
      "type": "Card",
      "props": {
        "title": "🧠 Quiz de Curiosidades",
        "subtitle": "Responda as perguntas e descubra sua pontuação!"
      },
      "children": ["header-badges"]
    },
    "header-badges": {
      "type": "Stack",
      "props": {
        "direction": "horizontal",
        "gap": 2
      },
      "children": ["badge-score", "badge-question"]
    },
    "badge-score": {
      "type": "Badge",
      "props": {
        "label": {
          "$template": "⭐ Pontuação: ${/score}"
        },
        "color": "yellow"
      },
      "children": []
    },
    "badge-question": {
      "type": "Badge",
      "props": {
        "label": {
          "$template": "📋 Pergunta ${/currentQuestion} de ${/totalQuestions}"
        },
        "color": "blue"
      },
      "children": []
    },
    "quiz-card": {
      "type": "Card",
      "props": {
        "title": ""
      },
      "visible": {
        "$state": "/finished",
        "not": true
      },
      "children": ["q1", "q2", "q3", "q4", "q5"]
    },

    "q1": {
      "type": "Stack",
      "props": { "direction": "vertical", "gap": 3 },
      "visible": { "$state": "/currentQuestion", "eq": 1 },
      "children": ["q1-text", "q1-opts", "q1-feedback", "q1-next"]
    },
    "q1-text": {
      "type": "Text",
      "props": { "content": "🌍 Qual é o maior oceano do mundo?", "size": "lg" },
      "children": []
    },
    "q1-opts": {
      "type": "Stack",
      "props": { "direction": "vertical", "gap": 2 },
      "children": ["q1-a", "q1-b", "q1-c", "q1-d"]
    },
    "q1-a": {
      "type": "Button",
      "props": {
        "label": "🌊 Oceano Atlântico",
        "variant": { "$cond": { "$state": "/selectedAnswer", "eq": "q1-a" }, "$then": "primary", "$else": "secondary" }
      },
      "on": {
        "press": [
          { "action": "setState", "params": { "statePath": "/selectedAnswer", "value": "q1-a" } },
          { "action": "setState", "params": { "statePath": "/answered", "value": true } },
          { "action": "setState", "params": { "statePath": "/feedback", "value": "❌ Errado! O Oceano Pacífico é o maior do mundo." } }
        ]
      },
      "children": []
    },
    "q1-b": {
      "type": "Button",
      "props": {
        "label": "🌊 Oceano Pacífico",
        "variant": { "$cond": { "$state": "/selectedAnswer", "eq": "q1-b" }, "$then": "primary", "$else": "secondary" }
      },
      "on": {
        "press": [
          { "action": "setState", "params": { "statePath": "/selectedAnswer", "value": "q1-b" } },
          { "action": "setState", "params": { "statePath": "/answered", "value": true } },
          { "action": "setState", "params": { "statePath": "/feedback", "value": "✅ Correto! O Oceano Pacífico é o maior do mundo!" } },
          { "action": "setState", "params": { "statePath": "/score", "value": { "$computed": "add", "args": { "a": { "$state": "/score" }, "b": 1 } } } }
        ]
      },
      "children": []
    },
    "q1-c": {
      "type": "Button",
      "props": {
        "label": "🌊 Oceano Índico",
        "variant": { "$cond": { "$state": "/selectedAnswer", "eq": "q1-c" }, "$then": "primary", "$else": "secondary" }
      },
      "on": {
        "press": [
          { "action": "setState", "params": { "statePath": "/selectedAnswer", "value": "q1-c" } },
          { "action": "setState", "params": { "statePath": "/answered", "value": true } },
          { "action": "setState", "params": { "statePath": "/feedback", "value": "❌ Errado! O Oceano Pacífico é o maior do mundo." } }
        ]
      },
      "children": []
    },
    "q1-d": {
      "type": "Button",
      "props": {
        "label": "🌊 Oceano Ártico",
        "variant": { "$cond": { "$state": "/selectedAnswer", "eq": "q1-d" }, "$then": "primary", "$else": "secondary" }
      },
      "on": {
        "press": [
          { "action": "setState", "params": { "statePath": "/selectedAnswer", "value": "q1-d" } },
          { "action": "setState", "params": { "statePath": "/answered", "value": true } },
          { "action": "setState", "params": { "statePath": "/feedback", "value": "❌ Errado! O Oceano Pacífico é o maior do mundo." } }
        ]
      },
      "children": []
    },
    "q1-feedback": {
      "type": "Badge",
      "props": {
        "label": { "$state": "/feedback" },
        "color": { "$cond": { "$state": "/selectedAnswer", "eq": "q1-b" }, "$then": "green", "$else": "red" }
      },
      "visible": { "$state": "/answered" },
      "children": []
    },
    "q1-next": {
      "type": "Button",
      "props": { "label": "Próxima Pergunta ➡️", "variant": "primary" },
      "visible": { "$state": "/answered" },
      "on": {
        "press": [
          { "action": "setState", "params": { "statePath": "/currentQuestion", "value": 2 } },
          { "action": "setState", "params": { "statePath": "/selectedAnswer", "value": "" } },
          { "action": "setState", "params": { "statePath": "/answered", "value": false } },
          { "action": "setState", "params": { "statePath": "/feedback", "value": "" } }
        ]
      },
      "children": []
    },

