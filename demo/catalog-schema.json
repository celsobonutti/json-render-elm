{
  "components": {
    "Card": {
      "props": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "subtitle": {
            "type": "string"
          }
        },
        "required": [
          "title"
        ],
        "additionalProperties": false
      },
      "description": "A card container with a title and optional subtitle",
      "slots": [
        "default"
      ]
    },
    "Button": {
      "props": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "type": "object",
        "properties": {
          "label": {
            "type": "string"
          },
          "variant": {
            "type": "string",
            "enum": [
              "primary",
              "secondary",
              "danger"
            ]
          }
        },
        "required": [
          "label"
        ],
        "additionalProperties": false
      },
      "description": "A clickable button",
      "slots": []
    },
    "Text": {
      "props": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "type": "object",
        "properties": {
          "content": {
            "type": "string"
          },
          "size": {
            "type": "string",
            "enum": [
              "sm",
              "md",
              "lg",
              "xl"
            ]
          }
        },
        "required": [
          "content"
        ],
        "additionalProperties": false
      },
      "description": "A text block",
      "slots": []
    },
    "Input": {
      "props": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "type": "object",
        "properties": {
          "placeholder": {
            "type": "string"
          },
          "label": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "description": "A text input field with an optional label",
      "slots": []
    },
    "Stack": {
      "props": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "type": "object",
        "properties": {
          "direction": {
            "type": "string",
            "enum": [
              "vertical",
              "horizontal"
            ]
          },
          "gap": {
            "type": "integer",
            "minimum": -9007199254740991,
            "maximum": 9007199254740991
          }
        },
        "additionalProperties": false
      },
      "description": "A flex container that stacks children vertically or horizontally",
      "slots": [
        "default"
      ]
    },
    "Image": {
      "props": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "type": "object",
        "properties": {
          "src": {
            "type": "string"
          },
          "alt": {
            "type": "string"
          }
        },
        "required": [
          "src",
          "alt"
        ],
        "additionalProperties": false
      },
      "description": "An image element",
      "slots": []
    },
    "Badge": {
      "props": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "type": "object",
        "properties": {
          "label": {
            "type": "string"
          },
          "color": {
            "type": "string",
            "enum": [
              "green",
              "red",
              "yellow",
              "blue",
              "gray"
            ]
          }
        },
        "required": [
          "label"
        ],
        "additionalProperties": false
      },
      "description": "A small colored badge/tag",
      "slots": []
    }
  },
  "actions": {
    "press": {
      "params": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "type": "object",
        "properties": {},
        "additionalProperties": false
      },
      "description": "Generic button press"
    },
    "export": {
      "params": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "type": "object",
        "properties": {
          "format": {
            "type": "string"
          }
        },
        "required": [
          "format"
        ],
        "additionalProperties": false
      },
      "description": "Export data in a given format"
    }
  },
  "functions": {
    "shout": {
      "params": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "type": "object",
        "properties": {
          "text": {
            "type": "string"
          }
        },
        "required": [
          "text"
        ],
        "additionalProperties": false
      },
      "returnType": {
        "$schema": "https://json-schema.org/draft/2020-12/schema",
        "type": "string"
      },
      "description": "Convert text to uppercase"
    }
  }
}
